AEGRA_LLM_API_KEY=
AEGRA_LLM_BASE_URL=
AEGRA_LLM_MODEL=
AEGRA_LLM_TIMEOUT_SEC=180

# Full-pentest lab startup contract for API/scripts.
AEGRA_MCP_ENABLED=1
AEGRA_MCP_CONFIG_PATH=configs/mcp.lab.full-pentest.json
AEGRA_LAB_PROFILE_PATH=lab/profiles/full_pentest_lab.yml

# AEGRA_LAB_FIXTURE_PATH is intentionally not set in the main process.
# The full-pentest MCP config passes it only to the MCP server subprocess, and
# it must not enter Planner payloads, StageAgent prompts, RuntimeState, KG or AG.
