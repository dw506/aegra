{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegra.local/schemas/benchmark-manifest.schema.json",
  "title": "Aegra Benchmark Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["benchmark_id", "name", "description", "source", "targets"],
  "properties": {
    "benchmark_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "source": {"enum": ["HTB", "VulnHub", "Custom", "XBOW"]},
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/target"}
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "name",
        "source",
        "difficulty",
        "os",
        "scope",
        "expected_services",
        "ground_truth_subtasks",
        "ground_truth_vulnerabilities",
        "success_conditions",
        "allowed_tools",
        "max_steps",
        "max_time_minutes",
        "risk_level",
        "notes"
      ],
      "properties": {
        "target_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "source": {"enum": ["HTB", "VulnHub", "Custom", "XBOW"]},
        "difficulty": {"type": "string"},
        "os": {"type": "string"},
        "scope": {"$ref": "#/$defs/scope"},
        "expected_services": {
          "type": "array",
          "items": {"$ref": "#/$defs/service"}
        },
        "ground_truth_subtasks": {
          "type": "array",
          "items": {"$ref": "#/$defs/subtask"}
        },
        "ground_truth_vulnerabilities": {
          "type": "array",
          "items": {"$ref": "#/$defs/vulnerability"}
        },
        "success_conditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "allowed_tools": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "max_steps": {"type": "integer", "minimum": 1},
        "max_time_minutes": {"type": "integer", "minimum": 1},
        "risk_level": {"enum": ["low", "medium", "high"]},
        "notes": {"type": "string"}
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorized_hosts", "cidr_whitelist", "target_url"],
      "properties": {
        "authorized_hosts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "cidr_whitelist": {
          "type": "array",
          "items": {"type": "string"}
        },
        "target_url": {"type": "string"}
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service_id", "host", "port", "protocol", "service_name"],
      "properties": {
        "service_id": {"type": "string", "minLength": 1},
        "host": {"type": "string", "minLength": 1},
        "port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "protocol": {"type": "string", "minLength": 1},
        "service_name": {"type": "string", "minLength": 1}
      }
    },
    "subtask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subtask_id", "category", "description", "success_evidence"],
      "properties": {
        "subtask_id": {"type": "string", "minLength": 1},
        "category": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "success_evidence": {"type": "string"}
      }
    },
    "vulnerability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vulnerability_id", "name", "cve", "service_id", "severity", "required_evidence"],
      "properties": {
        "vulnerability_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "cve": {"type": ["string", "null"]},
        "service_id": {"type": "string", "minLength": 1},
        "severity": {"type": "string", "minLength": 1},
        "required_evidence": {"type": "string"}
      }
    }
  }
}
