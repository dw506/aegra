{
  "servers": {
    "pentest-tools": {
      "transport": "stdio",
      "command": "python",
      "args": ["-m", "src.integrations.mcp_lab.server"],
      "cwd": "/app",
      "env": {
        "AEGRA_LAB_MODE": "1",
        "AEGRA_LAB_PROFILE_PATH": "/app/lab/profiles/full_pentest_lab.yml",
        "AEGRA_LAB_FIXTURE_PATH": "/app/lab/fixtures/full_pentest_lab.fixture.yml",
        "AEGRA_MCP_TOOLSET": "full_pentest"
      }
    },
    "external-tools": {
      "transport": "http",
      "url": "http://host.docker.internal:8765/mcp"
    }
  }
}
