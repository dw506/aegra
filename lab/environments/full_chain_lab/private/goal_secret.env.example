# Copy this file to .env in the same directory and fill in real values.
# NEVER commit the real .env file. Only commit this .example file.
#
# These values are used by GoalOracle to validate goal proof submissions.
# They are never passed to any LLM, never written to KG/AG/Runtime/logs.

AEGRA_FINAL_GOAL_MARKER=your_goal_marker_here
AEGRA_FINAL_GOAL_TOKEN=your_goal_token_here
AEGRA_ORACLE_SIGNING_KEY=your_signing_key_here
